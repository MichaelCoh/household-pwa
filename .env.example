# Copy to .env in the project root. Values: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — Web Push (Edge Function URL that sends VAPID notifications)
VITE_PUSH_SERVICE_URL=

# Optional — Tier 1 Google Calendar sync.
# Create an OAuth 2.0 Client (Web application) at https://console.cloud.google.com/apis/credentials
# and add your origin to "Authorized JavaScript origins" + redirect URI to "Authorized redirect URIs".
# The redirect URI is `<your origin>/settings`.
VITE_GOOGLE_CLIENT_ID=

# Edge Function secrets (set in Supabase Dashboard → Edge Functions → Manage Secrets):
#   GOOGLE_CLIENT_ID            — same as VITE_GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET        — from the same OAuth 2.0 client
#   GOOGLE_REDIRECT_URI         — same as the URI registered in Google Cloud Console
#   APP_PUBLIC_URL              — front-end origin (e.g. https://your-app.com); embedded
#                                 into ICS event descriptions for deep-linking back
